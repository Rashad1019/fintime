# Copy this file to .env and fill in your real key. Never commit .env.
OPENROUTER_API_KEY=
# Optional: pin persona analysis to exactly one model.
OPENROUTER_MODEL=
# Optional: comma-separated rotation list of models to try in order
# (free-tier models come and go — refresh this without touching code).
OPENROUTER_MODELS=
# Optional: where the watchlist SQLite file lives (defaults to project root).
FINCENT_DB_PATH=
# Backup market-data provider, used only when Yahoo Finance is unavailable.
# Sign up free at https://site.financialmodelingprep.com/developer/docs
FMP_API_KEY=
